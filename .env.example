MYAIDB=/path/to/your/db/directory		# Path to your DB directory with the MyAI directory
MODEL=/path/to/your/model.gguf			# Path to your model file
CTX_SIZE=12288							# Size of your model context window (MB)
USERS=alice,bob							# Users created at install
PORT=8080								# Server port for Flask (http://localhost:8080)
SECRET_KEY=your-secret-key-here			# required
OWM_API_KEY=your_openweathermap_key		# optional — weather skill only
OWM_UNITS=metric						# metric | imperial | standard
OWM_HOME_CITY=London,GB					# Set a default weather location for "Will it rain today" type questions
SEARCH_REGION=uk-en						# DDGS search region, options: uk-en, wt-wt